{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=Kheyr;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Database": {
    "UseSqlite": false
  },
  "Jwt": {
    "Issuer": "kheyr",
    "Audience": "kheyr-clients",
    "SigningKey": "kheyr-dev-signing-key-change-in-production-32chars-min",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "Otp": {
    "DevelopmentMode": true,
    "FixedCode": "123456"
  },
  "Pairing": {
    "SessionExpiryMinutes": 10
  },
  "DesktopRelay": {
    "RequestExpiryMinutes": 30
  }
}
